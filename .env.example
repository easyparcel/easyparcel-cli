# EasyParcel CLI — environment configuration
# Copy to .env (or export in your shell). Environment variables always
# override values stored in ~/.easyparcel/config.json and credentials.json.

# --- OAuth application credentials (from the EasyParcel Developer Hub) ---
EASYPARCEL_CLIENT_ID=
EASYPARCEL_CLIENT_SECRET=

# --- Tokens (for headless / CI / AI-agent use) ---
# If set, these are used directly and take precedence over stored tokens.
EASYPARCEL_ACCESS_TOKEN=
EASYPARCEL_REFRESH_TOKEN=

# --- Endpoint configuration ---
EASYPARCEL_BASE_URL=https://api.easyparcel.com
EASYPARCEL_API_VERSION=2026-03

# --- Profile selection (supports multiple accounts: live, demo, etc.) ---
EASYPARCEL_PROFILE=default

# --- Optional: override the config directory (default ~/.easyparcel) ---
# EASYPARCEL_CONFIG_DIR=
